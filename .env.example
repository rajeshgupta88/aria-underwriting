# ── LLM providers ──────────────────────────────────────────
# Provider is set in config/llm_config.yaml (default: openai)
# Only the key for the active provider needs to be set.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Aria server ────────────────────────────────────────────
W3_ENDPOINT=http://localhost:8002/enrich
ARIA_PORT=8001
HITL_MODE=terminal        # options: terminal | browser
SCORE_LOG_PATH=data/score_log.jsonl
DECISIONS_PATH=data/decisions.jsonl
SLA_HOURS=4
